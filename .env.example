# Copy this file to .env and fill in real values before running locally.
# Never commit the actual .env to git.

# Django secret key — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-this-to-a-long-random-string

# Set to False in production
DEBUG=True

# Comma-separated list of hostnames the server answers to
# Add your Railway / Render domain here when you deploy
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.up.railway.app

# Redis connection (Railway auto-injects this when you add a Redis plugin)
REDIS_URL=redis://localhost:6379

# Comma-separated WebSocket / CORS origins allowed to talk to this server
CORS_ALLOWED_ORIGINS=https://muntasir-uwu.github.io,http://localhost:8000,http://127.0.0.1:8000

# Full base URL of THIS server — used for the self-ping keep-alive.
# Leave blank to disable self-ping (e.g. in local dev).
SELF_PING_URL=https://your-app.up.railway.app
